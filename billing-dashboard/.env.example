# ── Billing adapters ──────────────────────────────────────────────────────────
# Deepgram — STT billing
# API key:    https://console.deepgram.com → API Keys
# Project ID: https://console.deepgram.com → Settings → Projects
DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=

# Groq — LLM billing (free key at https://console.groq.com — no credit card needed)
GROQ_API_KEY=
GROQ_USAGE_PROBE_MODEL=llama-3.1-8b-instant

# ElevenLabs — TTS billing
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5

# ── Voice pipeline only (not used for billing) ────────────────────────────────
# OpenAI is used for Whisper transcription and TTS in the demo pipeline.
# It is NOT tracked as a billing provider in the dashboard.
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# ── Infrastructure ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/billing
REDIS_URL=redis://localhost:6379/0

# Credits threshold — route to fallback provider below this value
CREDIT_THRESHOLD=50
